# Sharely platform (same as live-demo-vercel / live-demo-temporal)
SHARELY_API_URL=https://sharelyai-be-fd-endpoint-developmentb856a7f7-euevhbauhsdwfceg.z02.azurefd.net
SHARELY_WORKSPACE_ID=
SHARELY_WORKSPACE_API_KEY=

# LLM — used by the AI SDK plugin's auto-generated activity on the worker.
# The OpenAI provider reads OPENAI_API_KEY from the worker's environment.
# NOTE: the model id is set in src/workflow.ts (MODEL), not here — a workflow
# can't read env deterministically.
OPENAI_API_KEY=

# Temporal (shared by the server and the worker)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=sharely-agents-ai-sdk

# Agent server port
PORT=8084
