# Sharely platform (same as live-demo-vercel)
SHARELY_API_URL=https://api.sharely.ai
SHARELY_WORKSPACE_ID=
SHARELY_WORKSPACE_API_KEY=

# LLM (raw OpenAI Chat Completions — used by the worker activity)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Temporal (shared by the server and the worker)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=sharely-agents

# Agent server port
PORT=8082
