{
  "name": "sharely-live-demo-temporal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "dev": "node --import tsx/esm src/server.ts",
    "dev:worker": "tsc -p tsconfig.json && node dist/worker.js"
  },
  "dependencies": {
    "@sharelyai/adapter-temporal": "*",
    "@sharelyai/protocol": "*",
    "@sharelyai/server": "*",
    "@temporalio/activity": "^1.16.2",
    "@temporalio/client": "^1.16.2",
    "@temporalio/worker": "^1.16.2",
    "@temporalio/workflow": "^1.16.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@sharelyai/tsconfig": "*",
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
