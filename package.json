{
  "name": "sharelyai",
  "version": "0.0.1",
  "type": "commonjs",
  "description": "Monorepo for the Sharely Server SDK — build Sharely-compatible agent servers (HTTP, auth, persistence, SSE).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharelyai/sharely-server-sdk.git"
  },
  "author": "Sharely.ai Inc.",
  "bugs": {
    "url": "https://github.com/sharelyai/sharely-server-sdk/issues"
  },
  "homepage": "https://github.com/sharelyai/sharely-server-sdk#readme",
  "packageManager": "npm@11.6.4",
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rm -r node_modules",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "turbo": "^2.9.14"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@openai/agents": "^0.11.5",
    "@sharelyai/tsconfig": "*",
    "@temporalio/client": "^1.16.2",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.28.0",
    "esbuild-register": "^3.6.0",
    "fast-glob": "^3.3.3",
    "supertest": "^7.2.2",
    "vitest": "^3.2.6"
  }
}
