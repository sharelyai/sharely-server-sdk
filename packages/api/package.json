{
  "name": "@sharelyai/api",
  "version": "0.0.5",
  "description": "Typed client to sharelyai-be (Sharely Platform Services), generated from OpenAPI.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharelyai/sharely-server-sdk.git",
    "directory": "packages/api"
  },
  "homepage": "https://github.com/sharelyai/sharely-server-sdk/tree/main/packages/api#readme",
  "keywords": ["sharely", "agent", "api-client", "backplane", "sse", "ai"],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@sharelyai/protocol": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
