{
  "name": "@sharelyai/adapter-vercel-ai",
  "version": "0.0.4",
  "description": "Translates Vercel AI SDK streams into Sharely AgentEvents.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharelyai/sharely-server-sdk.git",
    "directory": "packages/adapter-vercel-ai"
  },
  "homepage": "https://github.com/sharelyai/sharely-server-sdk/tree/main/packages/adapter-vercel-ai#readme",
  "keywords": ["sharely", "agent", "adapter", "vercel-ai", "ai-sdk", "sse", "ai"],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@sharelyai/protocol": "*",
    "@sharelyai/tools": "*"
  },
  "peerDependencies": {
    "ai": ">=6"
  },
  "devDependencies": {
    "@sharelyai/conformance": "*",
    "ai": "6.0.191",
    "typescript": "^5.6.3"
  }
}
