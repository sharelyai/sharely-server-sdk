{
  "name": "@sharely/adapter-vercel-ai",
  "version": "0.0.1",
  "description": "Translates Vercel AI SDK streams into Sharely AgentEvents.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@sharely/protocol": "*",
    "@sharely/tools": "*"
  },
  "peerDependencies": {
    "ai": ">=4"
  },
  "devDependencies": {
    "@sharely/conformance": "*",
    "ai": "^5.0.0",
    "typescript": "^5.6.3"
  }
}
