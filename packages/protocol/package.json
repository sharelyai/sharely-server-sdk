{
  "name": "@sharelyai/protocol",
  "version": "0.0.4",
  "description": "Wire protocol types for the Sharely agent server SDK. Types only — no runtime code.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharelyai/sharely-server-sdk.git",
    "directory": "packages/protocol"
  },
  "homepage": "https://github.com/sharelyai/sharely-server-sdk/tree/main/packages/protocol#readme",
  "keywords": ["sharely", "agent", "protocol", "sse", "ai", "types"],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "typescript": "^5.6.3"
  }
}
