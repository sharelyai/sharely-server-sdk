{
  "name": "@sharelyai/server",
  "version": "0.0.7",
  "description": "Express runtime for Sharely-compatible agent servers. HTTP, auth, persistence, SSE encoding.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharelyai/sharely-server-sdk.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/sharelyai/sharely-server-sdk/tree/main/packages/server#readme",
  "keywords": ["sharely", "agent", "server", "express", "sse", "ai"],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@sharelyai/api": "*",
    "@sharelyai/protocol": "*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "typescript": "^5.6.3"
  }
}
