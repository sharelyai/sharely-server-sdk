{
  "name": "@sharely/conformance",
  "version": "0.0.1",
  "description": "Shared conformance harness — validates AgentEvent streams against the wire-protocol contract.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@sharely/protocol": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
