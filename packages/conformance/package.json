{
  "name": "@sharelyai/conformance",
  "version": "0.0.4",
  "description": "Shared conformance harness — validates AgentEvent streams against the wire-protocol contract.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharelyai/sharely-server-sdk.git",
    "directory": "packages/conformance"
  },
  "homepage": "https://github.com/sharelyai/sharely-server-sdk/tree/main/packages/conformance#readme",
  "keywords": ["sharely", "agent", "conformance", "protocol", "testing", "ai"],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@sharelyai/protocol": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
